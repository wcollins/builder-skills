{
  "_comment": "Template for an LCM action workflow. CRITICAL: the workflow MUST output a job variable named 'instance' containing the resource data. Use a merge task to build the instance object from job inputs. Without 'instance' in outputSchema, the LCM action fails validation.",
  "automation": {
    "name": "",
    "type": "automation",
    "canvasVersion": 3,
    "encodingVersion": 1,
    "font_size": 12,
    "tasks": {
      "workflow_start": {
        "name": "workflow_start",
        "groups": [],
        "nodeLocation": { "x": 300, "y": 600 }
      },
      "a1b2": {
        "name": "merge",
        "canvasName": "merge",
        "summary": "Build Instance Data",
        "description": "Builds the instance object from job variables. LCM requires this output.",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "data_to_merge": [
              { "key": "field_name", "value": { "task": "job", "variable": "input_var_name" } },
              { "key": "status", "value": { "task": "static", "variable": "provisioned" } }
            ]
          },
          "outgoing": {
            "merged_object": "$var.job.instance"
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": { "x": 600, "y": 600 }
      },
      "workflow_end": {
        "name": "workflow_end",
        "groups": [],
        "nodeLocation": { "x": 900, "y": 600 }
      }
    },
    "transitions": {
      "workflow_start": { "a1b2": { "type": "standard", "state": "success" } },
      "a1b2": { "workflow_end": { "type": "standard", "state": "success" } },
      "workflow_end": {}
    },
    "groups": [],
    "inputSchema": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "instance": { "type": "object" }
      }
    }
  }
}
