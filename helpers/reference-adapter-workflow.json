{
  "automation": {
    "name": "Change Ticket Create and Update",
    "description": "Creates a change ticket, extracts the ID, updates it",
    "type": "automation",
    "canvasVersion": 3,
    "encodingVersion": 1,
    "font_size": 12,
    "tasks": {
      "workflow_start": {
        "name": "workflow_start",
        "groups": [],
        "nodeLocation": {
          "x": 200,
          "y": 600
        }
      },
      "e1a1": {
        "name": "merge",
        "canvasName": "merge",
        "summary": "Build Ticket Body",
        "description": "Builds the ServiceNow body from job variables",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "data_to_merge": [
              {
                "key": "short_description",
                "value": {
                  "task": "job",
                  "variable": "short_description"
                }
              },
              {
                "key": "description",
                "value": {
                  "task": "job",
                  "variable": "description"
                }
              },
              {
                "key": "summary",
                "value": {
                  "task": "job",
                  "variable": "short_description"
                }
              }
            ]
          },
          "outgoing": {
            "merged_object": null
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 450,
          "y": 600
        }
      },
      "a1b2": {
        "name": "createChangeRequest",
        "canvasName": "createChangeRequest",
        "summary": "Create Change Ticket",
        "description": "Creates a ServiceNow change request",
        "location": "Adapter",
        "locationType": "Servicenow",
        "app": "Servicenow",
        "type": "automatic",
        "displayName": "ServiceNow",
        "variables": {
          "incoming": {
            "body": "$var.e1a1.merged_object",
            "adapter_id": "$var.job.adapter_id"
          },
          "outgoing": {
            "result": null
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 700,
          "y": 600
        }
      },
      "b2c3": {
        "name": "query",
        "canvasName": "query",
        "summary": "Extract Change ID",
        "description": "Extracts the change ID from the adapter response",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "pass_on_null": false,
            "query": "response.id",
            "obj": "$var.a1b2.result"
          },
          "outgoing": {
            "return_data": "$var.job.changeId"
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 950,
          "y": 600
        }
      },
      "c3d4": {
        "name": "updateChangeRequest",
        "canvasName": "updateChangeRequest",
        "summary": "Update Change Ticket",
        "description": "Updates the change ticket",
        "location": "Adapter",
        "locationType": "Servicenow",
        "app": "Servicenow",
        "type": "automatic",
        "displayName": "ServiceNow",
        "variables": {
          "incoming": {
            "changeId": "$var.job.changeId",
            "body": {
              "work_notes": "Automated update"
            },
            "adapter_id": "$var.job.adapter_id"
          },
          "outgoing": {
            "result": null
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 1200,
          "y": 600
        }
      },
      "ef01": {
        "name": "newVariable",
        "canvasName": "newVariable",
        "summary": "Set Error Status",
        "description": "Sets error flag on failure",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "name": "errorStatus",
            "value": "error"
          },
          "outgoing": {
            "value": "$var.job.errorStatus"
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 950,
          "y": 800
        }
      },
      "workflow_end": {
        "name": "workflow_end",
        "groups": [],
        "nodeLocation": {
          "x": 1450,
          "y": 600
        }
      }
    },
    "transitions": {
      "workflow_start": {
        "e1a1": {
          "type": "standard",
          "state": "success"
        }
      },
      "e1a1": {
        "a1b2": {
          "type": "standard",
          "state": "success"
        }
      },
      "a1b2": {
        "b2c3": {
          "type": "standard",
          "state": "success"
        },
        "ef01": {
          "type": "standard",
          "state": "error"
        }
      },
      "b2c3": {
        "c3d4": {
          "type": "standard",
          "state": "success"
        }
      },
      "c3d4": {
        "workflow_end": {
          "type": "standard",
          "state": "success"
        },
        "ef01": {
          "type": "standard",
          "state": "error"
        }
      },
      "ef01": {
        "workflow_end": {
          "type": "standard",
          "state": "success"
        }
      },
      "workflow_end": {}
    },
    "groups": [],
    "inputSchema": {
      "type": "object",
      "properties": {
        "short_description": {
          "title": "short_description",
          "type": "string"
        },
        "description": {
          "title": "description",
          "type": "string"
        },
        "adapter_id": {
          "title": "adapter_id",
          "type": "string"
        }
      },
      "required": [
        "short_description",
        "description"
      ]
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "changeId": {
          "title": "changeId",
          "type": "string"
        }
      }
    }
  }
}
