          "location": "Application",
          "locationType": null,
          "app": "WorkFlowEngine",
          "type": "operation",
          "displayName": "WorkFlowEngine",
          "variables": {
            "incoming": {
              "tr_id": "",
              "variableMap": {
                "formData": "$var.job.formData"
              },
              "options": {
                "extractOutput": true,
                "validateIncoming": true,
                "revertToDefaultValue": true
              }
            },
            "outgoing": {
              "serviceName": null,
              "duration": null
            },
            "error": "",
            "decorators": []
          },
          "groups": [],
          "actor": "Pronghorn",
          "scheduled": false,
          "nodeLocation": {
            "x": 500,
            "y": 600
          }
        },
        "c3d4": {
          "name": "getTime",
          "canvasName": "getTime",
          "summary": "Record Start Time",
