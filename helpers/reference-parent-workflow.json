{
  "automation": {
    "name": "Parent - Check Device",
    "description": "Runs child workflow, checks result, sets status",
    "type": "automation",
    "canvasVersion": 3,
    "encodingVersion": 1,
    "font_size": 12,
    "tasks": {
      "workflow_start": {
        "name": "workflow_start",
        "groups": [],
        "nodeLocation": {
          "x": 50,
          "y": 600
        }
      },
      "a1a1": {
        "name": "childJob",
        "canvasName": "childJob",
        "summary": "Get Device Info",
        "description": "Runs the child workflow to get device info",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "task": "",
            "workflow": "Child - Device Action",
            "variables": {
              "deviceName": {
                "task": "job",
                "value": "deviceName"
              }
            },
            "data_array": "",
            "transformation": "",
            "loopType": ""
          },
          "outgoing": {
            "job_details": null
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "job",
        "scheduled": false,
        "nodeLocation": {
          "x": 250,
          "y": 600
        }
      },
      "b2b2": {
        "name": "query",
        "canvasName": "query",
        "summary": "Extract Child Status",
        "description": "Gets taskStatus from child job output",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "pass_on_null": false,
            "query": "taskStatus",
            "obj": "$var.a1a1.job_details"
          },
          "outgoing": {
            "return_data": "$var.job.childStatus"
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 500,
          "y": 600
        }
      },
      "c3c3": {
        "name": "evaluation",
        "canvasName": "evaluation",
        "summary": "Check Child Status",
        "description": "Checks if child completed successfully",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "all_true_flag": true,
            "evaluation_groups": [
              {
                "all_true_flag": true,
                "evaluations": [
                  {
                    "operand_1": {
                      "task": "job",
                      "variable": "childStatus"
                    },
                    "operator": "==",
                    "operand_2": {
                      "task": "static",
                      "variable": "success"
                    }
                  }
                ]
              }
            ]
          },
          "outgoing": {
            "return_value": null
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 750,
          "y": 600
        }
      },
      "d4d4": {
        "name": "newVariable",
        "canvasName": "newVariable",
        "summary": "Set Success",
        "description": "Sets finalStatus to completed",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "name": "finalStatus",
            "value": "completed"
          },
          "outgoing": {
            "value": "$var.job.finalStatus"
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 1000,
          "y": 500
        }
      },
      "e5e5": {
        "name": "newVariable",
        "canvasName": "newVariable",
        "summary": "Set Failure",
        "description": "Sets finalStatus to failed",
        "location": "Application",
        "locationType": null,
        "app": "WorkFlowEngine",
        "type": "operation",
        "displayName": "WorkFlowEngine",
        "variables": {
          "incoming": {
            "name": "finalStatus",
            "value": "failed"
          },
          "outgoing": {
            "value": "$var.job.finalStatus"
          },
          "error": "",
          "decorators": []
        },
        "groups": [],
        "actor": "Pronghorn",
        "scheduled": false,
        "nodeLocation": {
          "x": 1000,
          "y": 700
        }
      },
      "workflow_end": {
        "name": "workflow_end",
        "groups": [],
        "nodeLocation": {
          "x": 1250,
          "y": 600
        }
      }
    },
    "transitions": {
      "workflow_start": {
        "a1a1": {
          "type": "standard",
          "state": "success"
        }
      },
      "a1a1": {
        "b2b2": {
          "type": "standard",
          "state": "success"
        }
      },
      "b2b2": {
        "c3c3": {
          "type": "standard",
          "state": "success"
        }
      },
      "c3c3": {
        "d4d4": {
          "type": "standard",
          "state": "success"
        },
        "e5e5": {
          "type": "standard",
          "state": "failure"
        }
      },
      "d4d4": {
        "workflow_end": {
          "type": "standard",
          "state": "success"
        }
      },
      "e5e5": {
        "workflow_end": {
          "type": "standard",
          "state": "success"
        }
      },
      "workflow_end": {}
    },
    "groups": [],
    "inputSchema": {
      "type": "object",
      "properties": {
        "deviceName": {
          "title": "deviceName",
          "type": "string"
        }
      },
      "required": [
        "deviceName"
      ]
    },
    "outputSchema": {
      "type": "object",
      "properties": {
        "childStatus": {
          "type": "string"
        },
        "finalStatus": {
          "type": "string"
        }
      }
    }
  }
}
